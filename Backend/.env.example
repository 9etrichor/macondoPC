# Backend Environment Variables Example
# Copy this file to .env on your deployment server

# Server Configuration
PORT=4000
NODE_ENV=IERG4210

# Database Configuration
DATABASE_URL="file:./dev.db"

# Security Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
SESSION_SECRET=your-super-secret-session-key-change-this-in-production-at-least-32-chars

# File Upload Configuration
UPLOAD_DIR=./uploads

# CORS Configuration (update with your actual domain in production)
# For production, replace with your actual frontend domain
# FRONTEND_URL=https://yourdomain.com
